function icon(name, size = 20) {
  return `<svg class="icon" viewBox="0 0 24 24" width="${size}" height="${size}">${ICONS[name] || ""}</svg>`;
}

/* ---------- 7. Brand / avatar helpers --------------------------------- */
function logoHTML() {
  return `<span style="display:flex;align-items:center;gap:10px"><img class="nav-logo" src="assets/inspiring-lecturer-logo.png?${ASSET_VER}" alt="Inspiring Lecturer" /><span style="width:1px;height:28px;background:#E2E8F0;display:inline-block;flex-shrink:0"></span><img class="nav-logo" src="assets/ktm_solutions_id_logo.png?${ASSET_VER}" alt="KTM Solutions" style="height:42px" /></span>`;
}
const AVATAR_COLORS = ["#215AA9", "#059669", "#D97706", "#7C3AED", "#DC2626", "#0891B2", "#DB2777", "#4F46E5"];
function initials(name) {
  return (name || "?").trim().split(/\s+/).slice(0, 2).map((w) => w[0] || "").join("").toUpperCase() || "?";
}
function avatarColor(name) {
  let h = 0;
  for (const ch of String(name || "")) h = (h * 31 + ch.charCodeAt(0)) % 9973;
  return AVATAR_COLORS[h % AVATAR_COLORS.length];
}

/* ---------- 8. Formatters --------------------------------------------- */
function fmtDate(d) {
  if (!d) return "-";
  return new Date(d).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" });
}
function fmtDateTime(d) {
  if (!d) return "-";
  return new Date(d).toLocaleString("id-ID", { day: "numeric", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" });
}
function fmtTime(t) { if (!t) return ""; return String(t).slice(0, 5); }
function isPast(d) { if (!d) return false; return new Date(d).getTime() < Date.now(); }
function timeAgo(d) {
  if (!d) return "";
  const s = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
  if (s < 60) return "baru saja";
  const m = Math.floor(s / 60); if (m < 60) return `${m} menit lalu`;
  const h = Math.floor(m / 60); if (h < 24) return `${h} jam lalu`;
  const days = Math.floor(h / 24); if (days < 7) return `${days} hari lalu`;
  const w = Math.floor(days / 7); if (w < 5) return `${w} minggu lalu`;
  return fmtDate(d);
}
function escapeHTML(s) {
  if (s == null) return "";
  return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

/* ---------- 9. Modal helper ------------------------------------------- */
function openModal(title, bodyHTML, opts = {}) {
  closeModal();
  const overlay = document.createElement("div");
  overlay.className = "modal-overlay";
  overlay.id = "app-modal";
  overlay.innerHTML = `
    <div class="modal ${opts.wide ? "wide" : ""}" role="dialog" aria-modal="true">
      <div class="modal-head">
        <h3>${escapeHTML(title)}</h3>
        <button class="btn-icon" data-close aria-label="Tutup">${icon("close", 18)}</button>
      </div>
      <div class="modal-body">${bodyHTML}</div>
    </div>`;
  overlay.addEventListener("click", (e) => {
    if (e.target === overlay || e.target.closest("[data-close]")) closeModal();
  });
  document.body.appendChild(overlay);
  return overlay;
}
function closeModal() {
  const m = document.getElementById("app-modal");
  if (m) m.remove();
}

/* ---------- 10. Confirm dialog (replaces window.confirm) -------------- */
function confirmDialog(opts = {}) {
  const {
    title = "Konfirmasi",
    message = "",
    confirmText = "Lanjutkan",
    cancelText = "Batal",
    danger = false,
    warn = false,
    icon: ic = danger ? "alert-triangle" : warn ? "alert-triangle" : "info",
    destructiveNote = danger,
  } = opts;
  const iconType = danger ? "danger" : warn ? "warn" : "info";
  return new Promise((resolve) => {
    closeModal();
    const overlay = document.createElement("div");
    overlay.className = "modal-overlay";
    overlay.id = "app-modal";
    overlay.style.cssText = "z-index:9999";
    overlay.innerHTML = `
      <div class="modal cdlg" role="dialog" aria-modal="true">
        <div class="cdlg-body">
          <div class="cdlg-icon-wrap ${iconType}">${icon(ic, 28)}</div>
          <div class="cdlg-title">${escapeHTML(title)}</div>
          <p class="cdlg-msg">${message}</p>
          ${destructiveNote ? `<p class="cdlg-note">${icon("alert-triangle",13)} Tindakan ini tidak dapat dibatalkan.</p>` : ""}
          <div class="cdlg-actions">
            <button class="btn btn-cancel" data-cancel>${escapeHTML(cancelText)}</button>
            <button class="btn ${danger ? "btn-danger" : "btn-primary"} btn-confirm" data-confirm>
              <span class="cdlg-btn-text">${escapeHTML(confirmText)}</span>
              <span class="cdlg-spinner"></span>
            </button>
          </div>
        </div>
      </div>`;
    const done = (val) => { overlay.remove(); resolve(val); };
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay || e.target.closest("[data-cancel]")) done(false);
      if (e.target.closest("[data-confirm]")) {
        e.target.closest("[data-confirm]").classList.add("loading");
        done(true);
      }
    });
    document.body.appendChild(overlay);
    requestAnimationFrame(() => overlay.querySelector("[data-confirm]").focus());
  });
}

/* ---------- 11. Toast helper (pill + progress + stack) ---------------- */
function _toastWrap() {
  let w = document.getElementById("toast-wrap");
  if (!w) { w = document.createElement("div"); w.id = "toast-wrap"; w.className = "toast-wrap"; document.body.appendChild(w); }
  return w;
}
function toast(msg, type = "success") {
  const ic = { success: "check-circle", error: "x-circle", info: "info", warning: "alert-triangle" }[type] || "check-circle";
  const el = document.createElement("div");
  el.className = `toast ${type}`;
  el.innerHTML = `${icon(ic, 17)}<span>${escapeHTML(msg)}</span><span class="bar"></span>`;
  _toastWrap().appendChild(el);
  setTimeout(() => { el.classList.add("out"); setTimeout(() => el.remove(), 220); }, 3000);
}

/* ---------- 12. Skeleton helper --------------------------------------- */
function skeletonCards(n = 4) {
  return `<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px">${Array.from({ length: n }).map(() => `<div class="skel skel-card"></div>`).join("")}</div>`;
}

/* ---------- 13. Navigation definitions (with sections) ---------------- */
const PARTICIPANT_NAV = [
  { href: "#training",  label: "Jadwal Training", icon: "presentation",    section: "Menu Utama" },
  { href: "#profile",   label: "Profil Saya",     icon: "user",            section: "Akun" },
];
const ADMIN_NAV = [
  { href: "#admin",           label: "Dashboard",     icon: "layout",        section: "Manajemen" },
  { href: "#adminPeserta",    label: "Peserta",        icon: "users",         section: "Manajemen" },
  { href: "#adminTraining",   label: "Training",       icon: "presentation",  section: "Manajemen" },
  { href: "#adminTugas",      label: "Tugas",          icon: "task",          section: "Manajemen" },
  { href: "#adminSubmission", label: "Submission",     icon: "inbox-in",      section: "Manajemen" },
  { href: "#adminKehadiran",  label: "Kehadiran",      icon: "user-check",    section: "Manajemen" },
  { href: "#adminAnalytics",  label: "Analitik",       icon: "bar-chart",     section: "Tools" },
  { href: "#adminForms",      label: "Form Builder",   icon: "clipboard",     section: "Tools" },
  { href: "#profile",         label: "Profil Saya",    icon: "user",          section: "Akun" },
];

const PAGE_TITLES = {
  dashboard: "Home", training: "Training", materi: "Materi", tugas: "Tugas", forms: "Formulir", feedback: "Feedback",
  profile: "Profil Saya",
  admin: "Dashboard", adminPeserta: "Peserta", adminTraining: "Training", adminMateri: "Materi",
  adminTugas: "Tugas", adminSubmission: "Submission", adminKehadiran: "Kehadiran",
  adminAnalytics: "Analitik", adminForms: "Form Builder",
};

function _updateActiveNav() {
  const hash = location.hash.slice(1);
  document.querySelectorAll(".nav-link").forEach((a) => {
    const linkHash = (a.getAttribute("href") || "").replace(/^#/, "");
    a.classList.toggle("active", linkHash === hash);
  });
  document.querySelectorAll(".bn-item").forEach((a) => {
    const linkHash = (a.getAttribute("href") || "").replace(/^#/, "");
    a.classList.toggle("active", linkHash === hash);
  });
  const bc = document.getElementById("breadcrumbCur");
  if (bc) bc.textContent = PAGE_TITLES[hash] || "";
}

/* ---------- 14. Render shared app shell ------------------------------- */
function renderShell(profile, navItems, roleLabel) {
  if (_shellRendered) { _updateActiveNav(); return; }
  _shellRendered = true;

  document.getElementById("page-loader")?.remove();

  const isAdmin = profile.role === "admin";
  const hash = location.hash.slice(1);

  let sidebarNav = "";
  let lastSection = null;
  navItems.forEach((n) => {
    if (n.section && n.section !== lastSection) {
      sidebarNav += `<p class="nav-section-label">${escapeHTML(n.section)}</p>`;
      lastSection = n.section;
    }
    const linkHash = n.href.replace(/^#/, "");
    const active = linkHash === hash ? "active" : "";
    sidebarNav += `<a class="nav-link ${active}" href="${n.href}"><span class="nav-icon-box">${icon(n.icon, 17)}</span><span>${n.label}</span></a>`;
  });

  const avColor = avatarColor(profile.full_name || profile.email);
  const inits = initials(profile.full_name || profile.email);
  const roleBadge = isAdmin
    ? `<span class="badge badge-primary">Administrator</span>`
    : `<span class="badge badge-success">Peserta</span>`;

  const bottomNav = !isAdmin
    ? `<nav class="bottom-nav">
        ${[
          { href: "#training", label: "Training", icon: "presentation" },
          { href: "#profile", label: "Profil", icon: "user" },
        ].map((n) => {
          const a = n.href.slice(1) === hash ? "active" : "";
          return `<a class="bn-item ${a}" href="${n.href}">${icon(n.icon, 21)}<span>${n.label}</span></a>`;
        }).join("")}
      </nav>`
    : "";

  const app = document.getElementById("app");
  if (!isAdmin) document.body.classList.add("has-bottom-nav");

  app.innerHTML = `
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-head">
        <div class="sidebar-logo-wrap">
          <img src="assets/inspiring-lecturer-logo.png?${ASSET_VER}" alt="Inspiring Lecturer" class="sidebar-logo" />
          <div class="sidebar-logo-divider"></div>
          <img src="assets/ktm_solutions_id_logo.png?${ASSET_VER}" alt="KTM Solutions" class="sidebar-logo sidebar-logo-ktm" />
        </div>
      </div>
      <nav>${sidebarNav}</nav>
      <div class="sidebar-foot">
        <div class="sidebar-copy"><span class="sidebar-copy-brand">Inspiring Lecturer by Paragon 2026</span><span class="sidebar-copy-sub">Copyright &copy; 2026 All Rights Reserved</span></div>
      </div>
    </aside>
    <div class="main">
      <header class="topbar">

        <div class="breadcrumb">
          <span>${isAdmin ? "Admin" : "ILP Academy"}</span>${icon("chevron-right", 14)}<span class="cur" id="breadcrumbCur">${PAGE_TITLES[hash] || ""}</span>
        </div>
        <div class="tb-logo-mobile">
          <img src="assets/inspiring-lecturer-logo.png?${ASSET_VER}" alt="ILP" class="tb-logo-img" />
          <div class="tb-logo-divider"></div>
          <img src="assets/ktm_solutions_id_logo.png?${ASSET_VER}" alt="KTM" class="tb-logo-img tb-logo-ktm" />
        </div>

        <div class="gsearch" id="gsearch">
          <div class="gsearch-box">
            ${icon("search", 17).replace('class="icon"', 'class="icon s-ico"')}
            <input type="text" id="gsearchInput" placeholder="Cari training, materi, tugas..." autocomplete="off" />
            <span class="gsearch-clear" id="gsearchClear" style="display:none">${icon("close", 15)}</span>
            <span class="gsearch-kbd" id="gsearchKbd">Ctrl K</span>
          </div>
          <div id="gsearchPop"></div>
        </div>

        <div class="tb-actions">
          <div class="profile-trigger" id="profileTrigger">
            <div class="who" style="text-align:right;line-height:1.25">
              <div class="name" style="font-size:13.5px;font-weight:600;color:#fff">${escapeHTML(profile.full_name || roleLabel)}</div>
              <div class="role" style="font-size:11.5px;color:rgba(255,255,255,0.65)">${roleLabel}</div>
            </div>
            <span class="avatar-init" style="background:${avColor}">${escapeHTML(inits)}</span>
          </div>
          <div id="profilePopWrap" style="position:relative"></div>
          <button class="tb-btn" id="notifBtn" aria-label="Notifikasi" title="Notifikasi">
            ${icon("bell", 24)}
            <span class="tb-badge" id="notifBadge" style="display:none">0</span>
          </button>
          <div id="notifPopWrap" style="position:relative"></div>
          <button class="tb-btn" id="signOutBtn" aria-label="Keluar" title="Keluar">
            ${icon("logout", 22)}
          </button>
        </div>
      </header>
      <main class="content" id="content"><div class="loader"><div class="spinner"></div>Memuat...</div></main>
      ${bottomNav}
    </div>`;

  document.getElementById("signOutBtn")?.addEventListener("click", signOut);

  const sidebar = document.getElementById("sidebar");
  const overlay = document.getElementById("sidebarOverlay");
  const toggle = document.getElementById("menuToggle");
  const openSidebar = () => { sidebar.classList.add("open"); overlay.classList.add("active"); };
  const closeSidebar = () => { sidebar.classList.remove("open"); overlay.classList.remove("active"); };
  if (toggle) toggle.addEventListener("click", () => (sidebar.classList.contains("open") ? closeSidebar() : openSidebar()));
  if (overlay) overlay.addEventListener("click", closeSidebar);
  sidebar.querySelectorAll(".nav-link").forEach((a) =>
    a.addEventListener("click", () => { if (window.innerWidth <= 860) closeSidebar(); })
  );

  // Swipe left to close sidebar
  let _touchStartX = 0, _touchStartY = 0;
  sidebar.addEventListener("touchstart", (e) => {
    _touchStartX = e.touches[0].clientX;
    _touchStartY = e.touches[0].clientY;
  }, { passive: true });
  sidebar.addEventListener("touchend", (e) => {
    const dx = e.changedTouches[0].clientX - _touchStartX;
    const dy = Math.abs(e.changedTouches[0].clientY - _touchStartY);
    if (dx < -40 && dy < 60) closeSidebar();
  }, { passive: true });

  _wireProfileMenu(profile, roleLabel, avColor, inits, roleBadge);
  _wireNotifications(profile);
  _wireGlobalSearch(profile);

}

/* ---------- 15. Profile dropdown -------------------------------------- */
function _wireProfileMenu(profile, roleLabel, avColor, inits, roleBadge) {
  const trigger = document.getElementById("profileTrigger");
  const wrap = document.getElementById("profilePopWrap");
  if (!trigger || !wrap) return;
  let open = false;
  const close = () => { open = false; wrap.innerHTML = ""; document.removeEventListener("click", outside); };
  const outside = (e) => { if (!wrap.contains(e.target) && !trigger.contains(e.target)) close(); };
  trigger.addEventListener("click", (e) => {
    e.stopPropagation();
    if (open) return close();
    open = true;
    wrap.innerHTML = `
      <div class="menu-pop" style="position:absolute;top:8px;right:0;width:240px">
        <div style="padding:14px 16px;border-bottom:1px solid var(--border)">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="avatar-init" style="background:${avColor}">${escapeHTML(inits)}</span>
            <div style="min-width:0">
              <div style="font-size:13.5px;font-weight:700;color:var(--ink-900);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHTML(profile.full_name || roleLabel)}</div>
              <div style="font-size:11.5px;color:var(--ink-500);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHTML(profile.email || "")}</div>
            </div>
          </div>
          <div style="margin-top:9px">${roleBadge}</div>
        </div>
        <button class="menu-item" id="pm-profile">${icon("user", 16)} Profil Saya</button>
        <div class="menu-sep"></div>
        <button class="menu-item" id="pm-logout" style="color:var(--bad)">${icon("logout", 16)} Keluar</button>
      </div>`;
    wrap.querySelector("#pm-profile").addEventListener("click", () => { close(); navigate("profile"); });
    wrap.querySelector("#pm-logout").addEventListener("click", signOut);
    setTimeout(() => document.addEventListener("click", outside), 0);
  });
}

/* ---------- 16. Notifications (provider supplied by main.js) ---------- */
async function _refreshNotifBadge(profile) {
  const badge = document.getElementById("notifBadge");
  if (!badge || typeof window.__ilpNotifs !== "function") return;
  try {
    const list = await window.__ilpNotifs(profile);
    const unread = list.filter((n) => !n.read).length;
    badge.textContent = unread > 9 ? "9+" : String(unread);
    badge.style.display = unread ? "grid" : "none";
  } catch (_) {}
}
function _wireNotifications(profile) {
  const btn = document.getElementById("notifBtn");
  const wrap = document.getElementById("notifPopWrap");
  if (!btn || !wrap) return;
  let open = false;
  const close = () => { open = false; wrap.innerHTML = ""; document.removeEventListener("click", outside); };
  const outside = (e) => { if (!wrap.contains(e.target) && !btn.contains(e.target)) close(); };

  btn.addEventListener("click", async (e) => {
    e.stopPropagation();
    if (open) return close();
    open = true;
    wrap.innerHTML = `<div class="notif-pop"><div class="notif-list"><div class="loader" style="min-height:120px"><div class="spinner"></div>Memuat...</div></div></div>`;
    const list = typeof window.__ilpNotifs === "function" ? await window.__ilpNotifs(profile) : [];
    const body = list.length
      ? list.map((n) => `
        <div class="notif-item ${n.read ? "" : "unread"}" data-nid="${escapeHTML(n.id)}" ${n.link ? `data-link="${escapeHTML(n.link)}"` : ""}>
          <span class="n-ico" style="background:${n.bg};color:${n.color}">${icon(n.icon || "bell", 16)}</span>
          <div style="flex:1;min-width:0">
            <div class="n-title">${escapeHTML(n.title)}</div>
            ${n.body ? `<div class="n-body">${escapeHTML(n.body)}</div>` : ""}
            <div class="n-time">${escapeHTML(n.time || "")}</div>
          </div>
          ${n.read ? "" : `<span class="notif-dot"></span>`}
        </div>`).join("")
      : `<div class="notif-empty">${icon("bell", 26)}<p style="margin-top:8px">Belum ada notifikasi.</p></div>`;
    wrap.innerHTML = `
      <div class="notif-pop">
        <div class="notif-head"><h4>Notifikasi</h4><button class="notif-mark" id="notifMarkAll">Tandai semua dibaca</button></div>
        <div class="notif-list">${body}</div>
      </div>`;
    wrap.querySelector("#notifMarkAll").addEventListener("click", () => {
      if (typeof window.__ilpMarkAllNotifs === "function") window.__ilpMarkAllNotifs(list);
      wrap.querySelectorAll(".notif-item").forEach((i) => { i.classList.remove("unread"); i.querySelector(".notif-dot")?.remove(); });
      _refreshNotifBadge(profile);
    });
    wrap.querySelectorAll(".notif-item").forEach((item) => {
      item.addEventListener("click", () => {
        if (typeof window.__ilpReadNotif === "function") window.__ilpReadNotif(item.dataset.nid);
        const link = item.dataset.link;
        close();
        _refreshNotifBadge(profile);
        if (link) navigate(link);
      });
    });
    setTimeout(() => document.addEventListener("click", outside), 0);
  });

  _refreshNotifBadge(profile);
}

/* ---------- 17. Global search (provider supplied by main.js) ---------- */
function _wireGlobalSearch(profile) {
  const box = document.getElementById("gsearch");
  const input = document.getElementById("gsearchInput");
  const pop = document.getElementById("gsearchPop");
  const clear = document.getElementById("gsearchClear");
  if (!box || !input) return;

  let timer = null, items = [], kbdIdx = -1;

  const closePop = () => { pop.innerHTML = ""; items = []; kbdIdx = -1; };
  const renderPop = (groups, q) => {
    items = [];
    let html = "";
    const order = ["menu", "training", "materi", "tugas", "peserta"];
    const labels = { menu: "Menu", training: "Training", materi: "Materi", tugas: "Tugas", peserta: "Peserta" };
    let total = 0;
    order.forEach((type) => {
      const g = (groups[type] || []).slice(0, 5);
      if (!g.length) return;
      html += `<div class="gsearch-group-label">${labels[type]}</div>`;
      g.forEach((r) => {
        const idx = items.length;
        items.push(r);
        total++;
        html += `<div class="gsearch-item" data-idx="${idx}">
          <span class="gs-ico">${icon(r.icon || "file", 16)}</span>
          <div style="min-width:0;flex:1">
            <div class="gs-title">${escapeHTML(r.title)}</div>
            ${r.desc ? `<div class="gs-desc">${escapeHTML(r.desc)}</div>` : ""}
          </div>
          ${r.badge ? `<span class="badge badge-primary" style="flex-shrink:0">${escapeHTML(r.badge)}</span>` : ""}
        </div>`;
      });
    });
    if (!total) {
      html = `<div class="gsearch-empty">${icon("search", 24)}<p style="margin-top:8px">Tidak ada hasil untuk "<strong>${escapeHTML(q)}</strong>"</p></div>`;
    }
    pop.innerHTML = `<div class="gsearch-pop">${html}</div>`;
    pop.querySelectorAll(".gsearch-item").forEach((el) => {
      el.addEventListener("click", () => {
        const r = items[+el.dataset.idx];
        input.value = ""; clear.style.display = "none"; closePop();
        if (r && r.hash) navigate(r.hash);
      });
    });
  };

  const doSearch = async () => {
    const q = input.value.trim();
    clear.style.display = q ? "grid" : "none";
    if (!q || typeof window.__ilpSearch !== "function") { closePop(); return; }
    const groups = await window.__ilpSearch(q, profile);
    renderPop(groups, q);
  };

  input.addEventListener("input", () => { clearTimeout(timer); timer = setTimeout(doSearch, 200); });
  input.addEventListener("focus", () => { if (input.value.trim()) doSearch(); });
  clear.addEventListener("click", () => { input.value = ""; clear.style.display = "none"; closePop(); input.focus(); });

  const setActive = (i) => {
    const els = pop.querySelectorAll(".gsearch-item");
    if (!els.length) return;
    kbdIdx = (i + els.length) % els.length;
    els.forEach((el, n) => el.classList.toggle("kbd-active", n === kbdIdx));
    els[kbdIdx].scrollIntoView({ block: "nearest" });
  };
  input.addEventListener("keydown", (e) => {
    const els = pop.querySelectorAll(".gsearch-item");
    if (e.key === "Escape") { input.value = ""; clear.style.display = "none"; closePop(); input.blur(); return; }
    if (!els.length) return;
    if (e.key === "ArrowDown") { e.preventDefault(); setActive(kbdIdx + 1); }
    else if (e.key === "ArrowUp") { e.preventDefault(); setActive(kbdIdx - 1); }
    else if (e.key === "Enter") {
      e.preventDefault();
      const target = kbdIdx >= 0 ? items[kbdIdx] : items[0];
      if (target && target.hash) { input.value = ""; clear.style.display = "none"; closePop(); navigate(target.hash); }
    }
  });

  document.addEventListener("click", (e) => { if (!box.contains(e.target)) closePop(); });

  /* Ctrl/Cmd + K to focus search */
  document.addEventListener("keydown", (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      input.focus();
      input.select();
    }
  });
}
